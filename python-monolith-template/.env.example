# ========================================
# MONOLITH V1.0 - GŁÓWNA KONFIGURACJA
# ========================================
PROJECT_NAME="Moja Nowa Usługa Webowa"
ENVIRONMENT="dev"  # dev / prod

# ----------------------------------------
# CORE FEATURE FLAGS (Włącz/Wyłącz)
# ----------------------------------------
# Jeśli USE_DB=False, system użyje fallbacku Pandas/CSV![cite: 4, 5]
USE_DB=False
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/dbname"

ENABLE_AUTH=True
ENABLE_ROLES=True
ENABLE_EVENTS=True
ENABLE_PLUGINS=True
ENABLE_BACKGROUND_TASKS=True

# ----------------------------------------
# MODUŁY BIZNESOWE (Capability Registry)
# ----------------------------------------
ENABLE_WALLET=True
ENABLE_LEDGER=True
ENABLE_FILES=True
ENABLE_SCRIPTS=True

# ----------------------------------------
# WEB UI & ADMIN PANEL
# ----------------------------------------
ENABLE_ADMIN_PANEL=True

# ----------------------------------------
# API, RESPONSE & ERRORS
# ----------------------------------------
API_V1_STR="/api/v1"
ENABLE_STANDARD_RESPONSE=True
ENABLE_GLOBAL_ERROR_HANDLER=True
ENABLE_HEALTH_CHECK=True
ENABLE_METRICS=True
DEFAULT_PAGINATION_LIMIT=20

# ----------------------------------------
# RATE LIMITING (slowapi)
# ----------------------------------------
ENABLE_RATE_LIMIT=True
RATE_LIMIT_WINDOW="1 minute"
RATE_LIMIT_MAX_REQUESTS=100

# ----------------------------------------
# SMTP / EMAIL SETTINGS
# ----------------------------------------
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""